# Mapetite environment template.
# Copy to `.env` for the frontend/root process and to `server/.env` for the backend.
# Do not commit real secrets.

# Frontend
VITE_RESTAURANTS_API_BASE_URL="http://127.0.0.1:5001"
VITE_AUTH_DEBUG="false"
VITE_MOCK_API_DEBUG="false"
VITE_APP_CONFIG_DEBUG="false"

# Auth/favorites API base. Leave blank for local Vite mock auth.
# In deployed demo mode, set to the same Render backend as VITE_RESTAURANTS_API_BASE_URL.
VITE_MCP_API_BASE_PATH=""
VITE_API_BASE_PATH=""
TENANT_ID=""

# Backend
MAPETITE_STORAGE_MODE="memory"
HOST="127.0.0.1"
PORT="5001"
CORS_ORIGIN="http://127.0.0.1:3000"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="300"
SEARCH_RATE_LIMIT_MAX="60"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mapetite"
MONGODB_URI="mongodb://localhost:27017/mapetite_cache"
GEOAPIFY_API_KEY="replace-with-your-geoapify-key"

# Backend diagnostics
MAPETITE_SEARCH_DEBUG="false"
SEARCH_DEBUG="false"
